# Dependencies
node_modules/
.pnpm-store/

# Build outputs
dist/
build/
*.tsbuildinfo

# Environment
.env
.env.local
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# Editor
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Test coverage
coverage/
.nyc_output/

# Temp
.tmp/
.cache/

# Diagnostic dumps (OPENCODE_ANYCLI_PROMPTLOG / OPENCODE_ANYCLI_CLINE_NDJSON_LOG
# / OPENCODE_ANYCLI_USAGELOG sinks). Often dropped at the repo root during
# debugging — keep them out of git so they never sneak into a commit.
*.ndjson
prompt.txt
prompt-*.log
cline-open*
cline-raw*

# Lockfiles are regenerated on every npm/bun install / install.sh run; tracking
# them churns the diff with no useful signal and breaks --update auto-stash.
package-lock.json
bun.lock
bun.lockb

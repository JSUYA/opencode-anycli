{
  "name": "opencode-anycli",
  "version": "0.1.0",
  "private": true,
  "description": "Bundle that runs the opencode AI coding agent through the locally installed cline CLI",
  "keywords": ["opencode", "cline", "ai-sdk", "coding-agent", "provider"],
  "license": "MIT",
  "author": "Project Maintainers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JSUYA/opencode-anycli.git"
  },
  "homepage": "https://github.com/JSUYA/opencode-anycli#readme",
  "bugs": "https://github.com/JSUYA/opencode-anycli/issues",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {

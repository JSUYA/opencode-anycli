{
  "name": "@opencode-anycli/provider-cline-cli",
  "version": "0.1.0",
  "description": "Vercel AI SDK v3 LanguageModelV3 adapter that delegates to a locally installed cline CLI subprocess.",
  "keywords": [
    "ai-sdk",
    "ai-sdk-provider",
    "cline",
    "opencode",
    "language-model-v3"
  ],
  "license": "MIT",
  "author": "Project Maintainers",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JSUYA/opencode-anycli.git",
    "directory": "packages/provider-cline-cli"
  },
  "homepage": "https://github.com/JSUYA/opencode-anycli/tree/main/packages/provider-cline-cli#readme",
  "bugs": "https://github.com/JSUYA/opencode-anycli/issues",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./openai-compat": {
      "types": "./dist/openai-compat.d.ts",
      "import": "./dist/openai-compat.js"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@agentclientprotocol/sdk": "^0.13.1",
    "@ai-sdk/provider": "^3.0.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsup": "^8.3.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20"
  }
}

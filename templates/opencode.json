{
  "$schema": "https://opencode.ai/config.json",
  "enabled_providers": [
    "cline",
    "claude",
    "codex"
  ],
  "lsp": true,
  "provider": {
    "cline": {
      "npm": "file://__OPENCODE_ANYCLI_PROVIDER_DIST__",
      "name": "Cline (cline CLI)",
      "models": {
        "GaussO4.1-CLI": {
          "name": "Cline GaussO4.1-CLI",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        },
        "GaussO3.3-CLI": {
          "name": "Cline GaussO3.3-CLI",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        }
      },
      "options": {
        "cli": "cline",
        "mode": "subprocess"
      }
    },
    "claude": {
      "npm": "file://__OPENCODE_ANYCLI_PROVIDER_DIST__",
      "name": "Claude (claude CLI)",
      "models": {
        "opus-4.8-high": {
          "name": "Claude Opus 4.8 · high effort",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "opus-4.8-xhigh": {
          "name": "Claude Opus 4.8 · xhigh effort",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "opus-4.8-max": {
          "name": "Claude Opus 4.8 · max effort",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "sonnet-high": {
          "name": "Claude Sonnet · high effort",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "sonnet-xhigh": {
          "name": "Claude Sonnet · xhigh effort",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        },
        "sonnet-max": {
          "name": "Claude Sonnet · max effort",
          "limit": {
            "context": 1000000,
            "output": 64000
          }
        }
      },
      "options": {
        "cli": "claude",
        "command": "claude"
      }
    },
    "codex": {
      "npm": "file://__OPENCODE_ANYCLI_PROVIDER_DIST__",
      "name": "Codex (codex CLI)",
      "models": {
        "gpt-5.4-high": {
          "name": "Codex GPT-5.4 · high effort",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        },
        "gpt-5.4-xhigh": {
          "name": "Codex GPT-5.4 · xhigh effort",
          "limit": {
            "context": 256000,
            "output": 8192
          }
        },
        "gpt-5.5-high": {
          "name": "Codex GPT-5.5 · high effort",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        },
        "gpt-5.5-xhigh": {
          "name": "Codex GPT-5.5 · xhigh effort",
          "limit": {
            "context": 400000,
            "output": 128000
          }
        }
      },
      "options": {
        "cli": "codex",
        "command": "codex"
      }
    }
  },
  "model": "cline/GaussO4.1-CLI",
  "small_model": "cline/GaussO4.1-CLI",
  "default_agent": "orchestrator",
  "agent": {
    "build": {
      "model": "cline/GaussO4.1-CLI"
    },
    "plan": {
      "model": "cline/GaussO4.1-CLI"
    },
    "compaction": {
      "model": "cline/GaussO4.1-CLI"
    },
    "summary": {
      "model": "cline/GaussO4.1-CLI"
    },
    "title": {
      "model": "cline/GaussO4.1-CLI"
    },
    "explore": {
      "model": "cline/GaussO4.1-CLI"
    },
    "general": {
      "model": "cline/GaussO4.1-CLI"
    },
    "orchestrator": {
      "model": "cline/GaussO4.1-CLI"
    }
  }
}
